# Copy to `.env.local` (git-ignored). Both the agent AND `ggui serve`
# read this file via dotenv-cli (`pnpm dev:ggui` and `pnpm dev:agent`).

# --- Required ---

# OpenAI API key — drives the agent (openai-agents-sdk).
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic API key — drives ggui's own UI generation (default
# servers/ggui/ggui.json picks Claude). Swap to an OpenAI model in
# ggui.json to drop this dep and run a single-vendor stack.
ANTHROPIC_API_KEY=

# --- Deploy to Railway (`pnpm deploy:railway`) ---

# Account/workspace API token — lets `pnpm deploy:railway` create the
# Railway project + services and deploy them in one command. Create an
# ACCOUNT token (NOT a project token) at https://railway.com/account/tokens
# Leave blank if you're not deploying to Railway.
RAILWAY_API_TOKEN=

# --- Wire the todo MCP into the agent (needed for the full demo) ---

# Set this so the agent registers the todo server's tools alongside
# the ggui_* tools. Leave unset to run the agent against ggui only.
GGUI_TODO_MCP_URL=http://localhost:6782/mcp

# --- Optional overrides (defaults shown) ---

# Where the agent's MCP client connects for ggui_* (render) tools.
# GGUI_MCP_URL=http://localhost:6781/mcp

# Bearer sent on every ggui MCP request. The default pairs with
# `ggui serve --dev-allow-all`, which accepts any non-empty bearer.
# GGUI_MCP_BEARER=dev

# OpenAI model the AGENT runs on.
# OPENAI_MODEL=gpt-5.5-2026-04-23
# GGUI_CONFIG_DIR=/data/.ggui
# GGUI_PERSISTENT_DIR=/data/.ggui/persistent
# GGUI_ADMIN_TOKEN=ggui_admin_replace_me
# GGUI_HIDE_ADMIN_TOKEN=1

# Agent backend HTTP port.
# PORT=6791

# Frontend SPA — where the browser bundle should hit the agent backend.
# VITE_AGENT_ENDPOINT_URL=http://localhost:6791
